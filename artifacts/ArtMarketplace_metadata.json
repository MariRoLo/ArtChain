			"kind": "user",
			"methods": {
				"FEE_BASIS_POINTS()": {
					"notice": "Fee del marketplace en basis points (250 = 2.5%)."
				},
				"accumulatedFees()": {
					"notice": "ETH acumulado por fees del marketplace, retirable por el owner."
