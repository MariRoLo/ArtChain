		"devdoc": {
			"author": "ArtChain Team — ISI UTN 2026",
			"details": "Llama a ArtNFT.mint() (cross-contract). Patrón CEI y ReentrancyGuard      en todas las funciones que manejan ETH para prevenir reentrancy.",
			"errors": {
				"OwnableInvalidOwner(address)": [
					{
						"details": "The owner is not a valid owner account. (eg. `address(0)`)"
					}
				],
				"OwnableUnauthorizedAccount(address)": [
					{
						"details": "The caller account is not authorized to perform an operation."
					}
				],
				"ReentrancyGuardReentrantCall()": [
					{
						"details": "Unauthorized reentrant call."
					}
				]
			},
			"kind": "dev",
			"methods": {
				"buyNFT(uint256)": {
					"details": "Patrón CEI:      1. CHECKS: listing activo, pago suficiente      2. EFFECTS: desactivar listing, calcular y acumular fee      3. INTERACTIONS: transferir NFT, pagar al vendedor, devolver excedente      El 2.5% de comisión queda retenido en el contrato para el owner.",
					"params": {
						"tokenId": "ID del NFT a comprar."
					}
				},
				"calculateFee(uint256)": {
					"params": {
						"salePrice": "Precio de venta en wei."
					},
					"returns": {
						"_0": "El monto del fee (2.5% del precio)."
					}
				},
				"cancelListing(uint256)": {
					"params": {
						"tokenId": "ID del NFT a deslistar."
					}
				},
				"constructor": {
					"details": "Luego del deploy, llamar a ArtNFT.setMinter(address(this)) para autorizar      este contrato a mintear NFTs.",
					"params": {
						"initialMintPrice": "Precio en wei para mintear un nuevo NFT (0 = gratis).",
						"nftAddress": "Dirección del contrato ArtNFT previamente deployado."
					}
				},
				"createNFT(string)": {
					"details": "INTERACCIÓN CROSS-CONTRACT: llama a ArtNFT.mint(). Patrón CEI:      1. CHECK: msg.value >= mintPrice      2. EFFECT: acumular fee      3. INTERACTION: llamar a ArtNFT.mint()",
					"params": {
						"uri": "URI de metadata IPFS del nuevo NFT (formato: ipfs://CID/metadata.json)."
					},
					"returns": {
						"tokenId": "El ID del token recién minteado."
					}
				},
				"getListing(uint256)": {
					"params": {
						"tokenId": "ID del token a consultar."
					},
					"returns": {
						"active": "Si el listing está activo.",
						"price": "Precio de venta en wei.",
						"seller": "Dirección del vendedor."
					}
				},
				"listNFT(uint256,uint256)": {
					"details": "El caller debe llamar a ArtNFT.approve(marketplace, tokenId) primero.",
					"params": {
						"price": "Precio de venta en wei. Debe ser mayor a cero.",
						"tokenId": "ID del NFT a listar."
					}
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"setMintPrice(uint256)": {
					"details": "Solo el owner puede llamarlo.",
					"params": {
						"newPrice": "Nuevo precio en wei (0 para minteo gratuito)."
					}
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"withdrawFees()": {
					"details": "Patrón CEI: saldo puesto a cero ANTES de transferir ETH."
				}
			},
			"title": "ArtMarketplace",
			"version": 1
		},
		"userdoc": {
			"errors": {
